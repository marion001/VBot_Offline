#!/usr/bin/env python3
import argparse
import base64
import json
import os
import re
import tempfile
import time

import broadlink


DEFAULT_JSON_FILE = "/home/pi/VBot_Offline/resource/broadlink/broadlink.json"
DEFAULT_PORT = 80
DISCOVER_TIMEOUT = 10
IR_POLL_INTERVAL = 0.2
RF_POLL_INTERVAL = 0.5
RF_CANCEL_DELAY = 1.5
RF_LISTEN_WINDOW = 4
RF_MAX_FIND_ERROR = 3


def normalize_mac(mac):
    mac_text = str(mac).strip().replace(":", "").replace("-", "").replace(" ", "")
    if len(mac_text) != 12 or not re.fullmatch(r"[0-9a-fA-F]{12}", mac_text):
        raise ValueError("MAC khong hop le")
    return mac_text.upper()


def parse_devtype(devtype):
    if isinstance(devtype, int):
        return devtype
    devtype_text = str(devtype).strip()
    try:
        return int(devtype_text, 16)
    except ValueError as e:
        raise ValueError("devtype khong hop le") from e


def encode_command(data):
    return base64.b64encode(data).decode("ascii")


def decode_command(code):
    try:
        return base64.b64decode(str(code).strip(), validate=True)
    except Exception as e:
        raise ValueError("Ma lenh IR/RF base64 khong hop le") from e


def load_json_file(json_file):
    if not os.path.exists(json_file):
        return {}
    try:
        with open(json_file, "r", encoding="utf-8") as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        raise ValueError(f"File JSON khong hop le: {e}") from e


def save_json_atomic(json_file, data):
    folder = os.path.dirname(json_file) or "."
    os.makedirs(folder, exist_ok=True)
    fd, tmp_path = tempfile.mkstemp(prefix=".broadlink_", suffix=".tmp", dir=folder)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=4, ensure_ascii=False)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp_path, json_file)
        os.chmod(json_file, 0o777)
    except Exception:
        try:
            os.remove(tmp_path)
        except OSError:
            pass
        raise


def get_device_name(device):
    device_text = str(device)
    match = re.search(r"\(([^()]+?)\s0x[0-9a-fA-F]+", device_text)
    return match.group(1) if match else "BroadLink Unknown"


def safe_cancel_rf(rm, delay=RF_CANCEL_DELAY):
    try:
        rm.cancel_sweep_frequency()
    except Exception:
        pass
    if delay:
        time.sleep(delay)


# Khoi tao thiet bi Broadlink.
def create_device(ip, mac, devtype, port=DEFAULT_PORT):
    try:
        rm = broadlink.gendevice(
            parse_devtype(devtype),
            (str(ip), int(port)),
            bytes.fromhex(normalize_mac(mac)),
        )
        rm.auth()
        return rm
    except Exception as e:
        raise Exception(f"Khong the tao hoac auth device: {e}")


# Hoc lenh IR.
def learn_ir(rm, timeout=9):
    start_time = time.time()
    try:
        rm.check_data()
    except (broadlink.exceptions.ReadError, broadlink.exceptions.StorageError):
        pass

    try:
        rm.enter_learning()
    except AttributeError:
        return None
    except Exception as e:
        raise Exception(f"Khong the bat dau hoc IR: {e}")

    while time.time() - start_time < timeout:
        time.sleep(IR_POLL_INTERVAL)
        try:
            data = rm.check_data()
            if data:
                return encode_command(data)
        except (broadlink.exceptions.ReadError, broadlink.exceptions.StorageError):
            continue
    return None


# Hoc lenh RF.
def learn_rf(rm, timeout=15):
    if not hasattr(rm, "sweep_frequency"):
        raise Exception("Thiet bi khong ho tro RF")

    safe_cancel_rf(rm)
    try:
        rm.sweep_frequency()
    except Exception:
        safe_cancel_rf(rm)
        return None

    locked_frequency = False
    for _ in range(20):
        try:
            if rm.check_frequency():
                locked_frequency = True
                break
        except Exception:
            safe_cancel_rf(rm, RF_POLL_INTERVAL)
        time.sleep(RF_POLL_INTERVAL)

    if not locked_frequency:
        safe_cancel_rf(rm)
        return None

    time.sleep(3)
    data = None
    start_time = time.time()
    find_error = 0

    while time.time() - start_time < timeout:
        try:
            rm.find_rf_packet()
            find_error = 0
        except Exception:
            find_error += 1
            safe_cancel_rf(rm, 1)
            if find_error >= RF_MAX_FIND_ERROR:
                break
            time.sleep(1)
            continue

        waited = 0
        while waited < RF_LISTEN_WINDOW:
            try:
                data = rm.check_data()
                if data:
                    break
            except (broadlink.exceptions.ReadError, broadlink.exceptions.StorageError):
                pass
            time.sleep(RF_POLL_INTERVAL)
            waited += RF_POLL_INTERVAL

        if data:
            break

        safe_cancel_rf(rm, 0.8)
        time.sleep(RF_POLL_INTERVAL)

    safe_cancel_rf(rm)
    return encode_command(data) if data else None


# Tim kiem thiet bi Broadlink.
def scan_broadlink_devices(JSON_FILE=DEFAULT_JSON_FILE):
    result = {"success": False, "message": "", "data": []}
    try:
        data = load_json_file(JSON_FILE)
        devices_remote = data.get("devices_remote", [])
        device_map = {}

        for device in devices_remote:
            mac = device.get("mac")
            if not mac:
                continue
            try:
                device_map[normalize_mac(mac)] = device
            except ValueError:
                continue

        devices = broadlink.discover(timeout=DISCOVER_TIMEOUT)
        if not devices:
            result["message"] = "Khong tim thay thiet bi Broadlink"
            return result

        for device in devices:
            name = get_device_name(device)
            ip, port = device.host
            mac = normalize_mac("".join(f"{byte:02X}" for byte in device.mac))
            device_map[mac] = {
                "friendly_name": name,
                "name": name,
                "model": name.replace("Broadlink ", ""),
                "devtype": hex(device.devtype),
                "ip": ip,
                "port": port,
                "mac": mac,
            }

        data["devices_remote"] = list(device_map.values())
        save_json_atomic(JSON_FILE, data)
        result["success"] = True
        result["data"] = data["devices_remote"]
        result["message"] = (
            f"Da cap nhat {len(devices)} thiet bi, "
            f"tong cong {len(data['devices_remote'])} thiet bi Broadlink"
        )
    except Exception as e:
        result["message"] = str(e)
    return result


# Gui lenh IR/RF.
def send_command(rm, code):
    try:
        rm.send_data(decode_command(code))
    except Exception as e:
        raise Exception(f"Gui lenh that bai: {e}")
